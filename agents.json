{
  "agents": [
    {
      "id": "claude-code",
      "display_name": "Claude Code",
      "provider": "Anthropic",
      "base_image": "Node.js 24",
      "non_root": true,
      "image_dir": "agents/claude-code",
      "entrypoint": "claude",
      "config_dir_host": ".claude",
      "config_path_container": "/home/node/.claude",
      "docs_url": "https://docs.anthropic.com/en/docs/claude-code/overview",
      "update_hint": "curl -fsSL https://claude.ai/install.sh | bash",
      "run": {
        "mounts": [
          {
            "host": "$HOME/.claude",
            "container": "/home/node/.claude"
          },
          {
            "host": "$HOME/.claude/.claude.json",
            "container": "/home/node/.claude.json"
          }
        ],
        "env_vars": [
          "ANTHROPIC_API_KEY"
        ],
        "docker_args": [],
        "command_args": [
          "--verbose",
          "--dangerously-skip-permissions"
        ]
      }
    },
    {
      "id": "codex-cli",
      "display_name": "Codex CLI",
